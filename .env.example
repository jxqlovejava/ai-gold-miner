# API Keys
# FRED API Key (免费申请: https://fred.stlouisfed.org/docs/api/api_key.html)
# 用于美元指数、实际利率、通胀预期等宏观数据
FRED_API_KEY=your_fred_api_key_here

# NewsAPI Key (https://newsapi.org/)
# 用于黄金相关新闻抓取和情感分析
NEWS_API_KEY=your_newsapi_key_here

# Tavily API Key (https://tavily.com/)
# 用于文章交叉验证搜索
TAVILY_API_KEY=your_tavily_key_here

# LLM API Key (可选)
# 用于文章深度分析增强
LLM_API_KEY=your_llm_api_key_here

# Data Sources
YAHOO_SYMBOL_SPOT=XAUUSD=X
YAHOO_SYMBOL_GLD=GLD
YAHOO_SYMBOL_IAU=IAU
YAHOO_SYMBOL_DXY=DX-Y.NYB

# Trading Parameters
INITIAL_CAPITAL_USD=100000
MAX_POSITION_PCT=0.8
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.06

# Risk Profile: aggressive | moderate | conservative
RISK_PROFILE=moderate

# Notification (企业微信机器人 Webhook)
WECHAT_WEBHOOK_URL=
ENABLE_NOTIFICATION=false

# Self-Improvement Loop
# 是否在每次 scan 后自动记录预测
ENABLE_AUTO_TRACKING=true

# Price Alerts
ALERT_BIG_MOVE_PCT=2.0
ALERT_DXY_MOVE_PCT=1.0
ALERT_KEY_LEVEL_LOOKBACK=20
ALERT_GOLD_SILVER_RATIO_HIGH=85.0
ALERT_GOLD_SILVER_RATIO_LOW=60.0

# Proxy (科学上网)
# mihomo/clash 订阅链接
MIHOMO_SUB_URL=

# Polymarket 预测市场
POLYMARKET_ENABLED=true
POLYMARKET_MIN_VOLUME=500.0
POLYMARKET_MAX_MARKETS=20

# Paths
DATA_DIR=./data
LOG_LEVEL=INFO
